programa {
  funcao inicio() {

    real not1, not2, not3, media

    escreva("Digite a primeira nota: ")
    leia(not1)
    escreva("Digite a segunda nota: ")
    leia(not2)
    escreva("Digite a terceira nota: ")
    leia(not3)

    media =( (not1 * 2) + (not2 * 3) + (not3 * 5) ) / (2+3+5)

    escreva("A média ponderada seá: ", media)
    
  }
}
