programa {
  funcao inicio() {

    real dias, anos, meses, total

    escreva("Digite a sua idade em dias: ")
    leia(dias)
    

    meses = dias / 30
    anos = dias / 365

    escreva("A sua idade em meses é: ", meses, " meses")
    escreva("\nA sua idade em anos é: ", anos, " anos")
    
  }
}
